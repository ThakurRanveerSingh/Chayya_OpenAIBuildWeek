import { test, expect } from '@playwright/test';

test('test', async ({ page }) => {
  await page.goto('https://www.bing.com/search?q=stocks+technical+indicators&rdr=1&rdrig=AFF071568DAB4C399F8F1721F2C8BC15');
  const page1Promise = page.waitForEvent('popup');
  await page.getByRole('link', { name: 'Yahoo Finance - Stock Market' }).click();
  const page1 = await page1Promise;
  await page1.getByRole('link', { name: 'BTC-USD Bitcoin USD 64,684.70' }).click();
  await page1.getByTestId('fes-spotlight-overlay-content').getByRole('button', { name: 'Close' }).click();
  await page1.getByRole('tab', { name: '6M' }).click();
  await page1.getByTestId('chart-settings-button').click();
  await page1.getByRole('menuitem', { name: 'Chart' }).click();
  await page1.goto('https://finance.yahoo.com/quote/BTC-USD/chart/#');
  await page1.getByRole('button', { name: 'Technicals' }).click();
  await page1.getByRole('button', { name: 'Comparisons' }).click();
  await page1.getByRole('button', { name: 'Chart Type Selector' }).click();
  await page1.getByRole('option', { name: 'Candle', exact: true }).click();
  await page1.getByRole('button', { name: 'Technicals' }).click();
  await page1.getByText('Short Term').click();
  await page1.getByRole('button', { name: 'Settings' }).click();
  await page1.locator('.stx-subholder').click();
  await page1.goto('https://finance.yahoo.com/quote/BTC-USD/chart/#');
  await page1.getByRole('button', { name: 'Draw' }).click();
  await page1.locator('.stx-subholder').click();
  await page1.locator('.stx-subholder').click();
  await page1.getByRole('radio', { name: 'Arrow (Alt+A)' }).click();
  await page1.getByRole('radio', { name: 'Arrow (Alt+A)' }).click();
  await page1.getByRole('radio', { name: 'Line (Alt+L)' }).click();
  await page1.locator('.stx-subholder').click();
  await page1.locator('.stx-subholder').click();
  await page1.getByRole('button', { name: 'Technicals' }).click();
  await page1.getByText('View all technical patterns').click();
  await page1.getByTestId('quote-nav-bar').getByRole('menuitem', { name: 'News' }).click();
  await page1.getByRole('link', { name: 'LCID Lucid Group, Inc. 7.36 +' }).click();
  await page1.getByRole('button', { name: 'Chart Type' }).click();
  await page1.getByRole('option', { name: 'Line', exact: true }).click();
});